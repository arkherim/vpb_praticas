# Local development environment variables for the backend.
# For production/Render, provide a full DATABASE_URL or PostgreSQL credentials via env vars.

# Preferred production / Render value:
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require&channel_binding=require

# Optional local development fallback using separate PG variables:
# PGHOST=localhost
# PGDATABASE=vpb_praticas_local
# PGUSER=user
# PGPASSWORD=password
# PGSSLMODE=prefer
# PGCHANNELBINDING=require

# Local defaults for app startup:
APP_ENV=local
PORT=8000
